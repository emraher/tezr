# R project files
^.*\.Rproj$
^\.Rproj\.user$

# Package-development metadata
^\.git$
^\.github$
^\.lintr$
^codecov\.yml$
^cran-comments\.md$
^CONTRIBUTING\.md$
^CODE_OF_CONDUCT\.md$
^DESIGN\.md$
^LICENSE\.md$
^CITATION\.cff$

# Development-only scripts and data
^data-raw$
^scripts$
^profiling$

# Generated documentation and caches
^_pkgdown\.yml$
^docs$
^pkgdown$
^README\.Rmd$
^README\.html$
^README_cache$
^README_files$
^cache$
^figure$
^man/figures/architecture\.png$
^vignettes/.*_cache$
^vignettes/.*\.html$

# Manuscript and presentation material
^paper$
^presentation$
^slides$
^coarse-output$

# Local assistant state
^AGENTS\.md$
^\.claude$
^\.gemini-clipboard$
^\.positai$

# Miscellaneous local artifacts
^plan\.md$
^todo\.md$
^texput\.log$
^build$
^doc$
^Meta$
